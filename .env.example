# PostgreSQL 접속 URL
DATABASE_URL=postgresql://user:password@host:port/dbname

# Notion Internal Integration 토큰
NOTION_API_KEY=ntn_xxxxxxxxxxxxx

# Notion 데이터베이스를 생성할 상위 페이지 ID
NOTION_PARENT_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (선택) 이미 생성된 Notion DB ID — 없으면 자동 생성
# NOTION_DATABASE_ID=

# 동기화 대상 PostgreSQL 테이블명
SYNC_TABLE_NAME=your_table_name

# 생성 시각 컬럼명 (기본값: created_at)
# SYNC_TIMESTAMP_COLUMN=created_at

# 한 번에 가져올 최대 행 수 (기본값: 100)
# SYNC_BATCH_LIMIT=100
